{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "neotieba",
  "version": "0.1.0",
  "identifier": "com.vkango.neotieba",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1143",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeoTieBa",
        "width": 1366,
        "height": 800,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "proto/**/*"
    ]
  }
}
